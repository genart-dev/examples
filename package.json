{
  "name": "@genart-dev/examples",
  "version": "0.1.2",
  "description": "Curated gallery sketches for genart.dev — 14 generative art examples across 5 renderers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./sketches/*": "./sketches/*"
  },
  "files": [
    "dist",
    "sketches"
  ],
  "license": "MIT",
  "author": {
    "name": "genart.dev",
    "email": "support@genart.dev",
    "url": "https://genart.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/genart-dev/examples.git"
  },
  "homepage": "https://genart.dev",
  "keywords": [
    "genart",
    "generative-art",
    "examples",
    "gallery",
    "p5",
    "three",
    "glsl",
    "svg",
    "canvas2d"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "validate": "tsx validate.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@genart-dev/format": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
