  "algorithm": "function sketch(ctx){var W=1200,H=1040,rH=160;ctx.fillStyle='#0A0A0A';ctx.fillRect(0,0,W,H);ctx.fillStyle='#E0E0E0';ctx.font='bold 24px sans-serif';ctx.fillText('Natural Language Style Suggestions',20,36);ctx.font='13px sans-serif';ctx.fillStyle='#666';ctx.fillText('suggestStyles(prompt) \\u2192 ranked style + recipe matches with confidence',20,56);var sg=[[\"dark moody Japanese ink landscape\",[[\"Sumi-e — Mountain Landscape\",\"recipe\",85,\"Recipe matches: dark, atmospheric\",[\"#F5EFE2\",\"#1A1410\",\"#3A2E22\",\"#6A5C48\",\"#CC2200\"]],[\"Sumi-e (Ink Wash)\",\"style\",75,\"Matches themes: dark, atmospheric, night\",null],[\"Impressionism\",\"style\",75,\"Matches themes: dark, atmospheric, night\",null],[\"Impressionist Landscape\",\"recipe\",70,\"Recipe matches: dark, atmospheric\",[\"#87CEEB\",\"#228B22\",\"#FFD700\",\"#8B4513\",\"#F5F5DC\",\"#4169E1\",\"#90EE90\"]],[\"Ukiyo-e\",\"style\",60,\"Matches themes: dark, atmospheric, night\",null]]],[\"vibrant pop art with bold geometric shapes\",[[\"Memphis Design\",\"style\",60,\"Matches themes: geometric, abstract, systematic\",null],[\"Op Art — Vasarely Grid\",\"recipe\",55,\"Recipe matches: geometric, abstract\",[\"#000000\",\"#FFFFFF\",\"#FF6600\",\"#0066FF\",\"#FFFF00\",\"#FF0099\",\"#00FF99\"]],[\"Bauhaus Geometric Composition\",\"recipe\",55,\"Recipe matches: geometric, abstract\",[\"#CC0000\",\"#003366\",\"#FFCC00\",\"#000000\",\"#F5F0E8\",\"#FFFFFF\",\"#888888\"]],[\"Hard-Edge Painting\",\"style\",45,\"Matches themes: geometric, abstract, systematic\",null],[\"Op Art\",\"style\",45,\"Matches themes: geometric, abstract, systematic\",null]]],[\"peaceful minimal zen composition\",[[\"Sumi-e (Ink Wash)\",\"style\",95,\"Matches themes: japanese, zen, ink\",null],[\"Sumi-e — Bamboo\",\"recipe\",85,\"Recipe matches: japanese, zen\",[\"#F8F2E4\",\"#2A2010\",\"#4A3820\",\"#7A6650\",\"#CC2200\"]],[\"Wabi-Sabi\",\"style\",75,\"Matches themes: japanese, zen, ink\",null],[\"Minimalist Composition\",\"recipe\",55,\"Recipe matches: japanese, zen\",[\"#F8F8F5\",\"#2A2A2A\",\"#7A7A7A\",\"#C8B89A\",\"#4A7AB5\"]],[\"Minimalist Grid\",\"recipe\",55,\"Recipe matches: japanese, zen\",[\"#F0EDE5\",\"#8A8070\",\"#B0A890\",\"#C8C0B0\",\"#6A6258\"]]]],[\"swirling turbulent night sky with stars\",[[\"Vincent van Gogh\",\"style\",45,\"Matches themes: dark, atmospheric, night\",null],[\"Pastel\",\"style\",45,\"Matches themes: dark, atmospheric, night\",null],[\"Van Gogh — Starry Night\",\"recipe\",40,\"Recipe matches: dark, atmospheric\",[\"#1C2B6A\",\"#4169E1\",\"#FFD700\",\"#0D1B2A\",\"#87CEEB\",\"#F0E68C\",\"#2F4F4F\"]],[\"Generative — Flow Field\",\"recipe\",40,\"Recipe matches: dark, atmospheric\",[\"#0D0D0D\",\"#E8D4A8\",\"#7EB8D4\",\"#D4987E\",\"#A8C4A8\",\"#C4A8C4\"]],[\"Sumi-e — Mountain Landscape\",\"recipe\",40,\"Recipe matches: dark, atmospheric\",[\"#F5EFE2\",\"#1A1410\",\"#3A2E22\",\"#6A5C48\",\"#CC2200\"]]]],[\"retro 80s neon grid\",[[\"Synthwave / Retrowave\",\"style\",60,\"Matches themes: retro, vintage, 80s\",null],[\"Synthwave — Retrowave Grid\",\"recipe\",55,\"Recipe matches: retro, vintage\",[\"#0D0026\",\"#3D005A\",\"#FF006E\",\"#FF9900\",\"#FF00CC\",\"#00FFCC\",\"#FFFFFF\"]],[\"Memphis Design\",\"style\",45,\"Matches themes: retro, vintage, 80s\",null],[\"Pixel Art\",\"style\",45,\"Matches themes: retro, vintage, 80s\",null],[\"Vaporwave\",\"style\",45,\"Matches themes: retro, vintage, 80s\",null]]],[\"soft impressionist garden in sunlight\",[[\"Watercolor\",\"style\",45,\"Matches themes: light, luminous, bright\",null],[\"Claude Monet\",\"style\",45,\"Matches themes: light, luminous, bright\",null],[\"Impressionism\",\"style\",45,\"Matches themes: light, luminous, bright\",null],[\"Color Field\",\"style\",45,\"Matches themes: light, luminous, bright\",null],[\"Mark Rothko\",\"style\",45,\"Matches themes: light, luminous, bright\",null]]]];for(var p=0;p<sg.length;p++){var prompt=sg[p][0],results=sg[p][1],y=80+p*rH;ctx.fillStyle='#1A1A1A';ctx.fillRect(16,y,W-32,rH-8);ctx.fillStyle='#E0E0E0';ctx.font='bold 13px sans-serif';ctx.fillText('\"'+prompt+'\"',28,y+20);for(var s=0;s<Math.min(results.length,5);s++){var r=results[s],sx=28+s*220,sy=y+36;ctx.fillStyle='#252525';ctx.fillRect(sx,sy,200,6);var cc=r[2]>60?'#2B8B6B':r[2]>40?'#E07B39':'#555';ctx.fillStyle=cc;ctx.fillRect(sx,sy,200*r[2]/100,6);ctx.fillStyle='#AAA';ctx.font='bold 11px sans-serif';var nm=r[0].length>26?r[0].slice(0,24)+'...':r[0];ctx.fillText(nm,sx,sy+20);ctx.fillStyle='#666';ctx.font='10px sans-serif';ctx.fillText(r[1]+' \\u2014 '+r[2]+'%',sx,sy+34);if(r[4]){for(var c=0;c<Math.min(r[4].length,7);c++){ctx.fillStyle=r[4][c];ctx.fillRect(sx+c*14,sy+55,12,12);}}}}return{};}",
